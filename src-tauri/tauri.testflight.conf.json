{
	"$schema": "../node_modules/@tauri-apps/cli/schema.json",
	"build": {
		"beforeBuildCommand": "VITE_FANGUARD_DISTRIBUTION=app-store pnpm run build"
	},
	"app": {
		"macOSPrivateApi": false,
		"security": {
			"capabilities": [
				{
					"identifier": "main-window-testflight",
					"description": "Main TestFlight window permissions without self-updater access.",
					"windows": ["main"],
					"platforms": ["macOS"],
					"permissions": [
						"core:default",
						"core:window:allow-hide",
						"core:window:allow-show",
						"core:window:allow-set-always-on-top",
						"core:window:allow-set-focus",
						"core:window:allow-close",
						"core:window:allow-minimize",
						"core:window:allow-set-size"
					]
				}
			]
		}
	},
	"bundle": {
		"externalBin": [],
		"macOS": {
			"entitlements": "Entitlements.testflight.plist",
			"signingIdentity": null
		}
	},
	"plugins": {
		"updater": {
			"endpoints": []
		}
	}
}
